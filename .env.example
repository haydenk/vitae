# .env — personal build defaults
# Copy to .env and adjust. Values here are overridden by flags passed directly
# to mise tasks (e.g. mise run build resume.tex -n John_Doe takes priority).
#
# Usage reference:
#   mise run build [<input>] [-n <name>] [-o <outdir>] [--open] [--clean-aux]
#   mise run watch [<input>] [-n <name>] [-o <outdir>]
#   mise run clean [-o <outdir>]
#   mise run release <version>

# Source .tex file to compile (default: resume.tex)
# INPUT=resume.tex

# Output PDF base name, no extension (default: stem of INPUT)
# NAME=your_name

# Output directory (default: out)
# OUTDIR=out

# Open PDF in default viewer after build (default: false)
# OPEN=true

# Remove auxiliary LaTeX files after build (default: false)
# CLEAN_AUX=true
