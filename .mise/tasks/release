#!/usr/bin/env bash
#MISE description="Bump VERSION on develop and push — open a PR to master to trigger the release"
#MISE confirm="This will commit and push the new version to develop. Continue?"

#USAGE arg "<version>" help="Version string to release (e.g. 2026.05 → tag v2026.05)"

set -euo pipefail

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "ERROR: Working tree is dirty. Commit or stash changes before releasing."
  exit 1
fi

current_branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$current_branch" != "develop" ]; then
  echo "ERROR: Must be on develop to cut a release (current: $current_branch)"
  exit 1
fi

echo "${usage_version}" > VERSION
git add VERSION
git commit -m "chore: bump version to ${usage_version}"
git push origin develop

echo ""
echo "VERSION updated to ${usage_version} and pushed to develop."
echo "Open a pull request from develop → master to trigger the release."
